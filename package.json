{
  "name": "daw-harmony-lab",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Klyve-09/Music-Theory-Guide-Korean.git"
  },
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=22.0.0 <25",
    "npm": ">=10"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:release": "node scripts/validate-production-env.mjs && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "smoke:prod": "node scripts/smoke-production.mjs",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build && npm run smoke:prod",
    "verify:release": "node scripts/validate-production-env.mjs && npm run lint && npm run typecheck && npm run test && npm run build && npm run smoke:prod"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "lucide-react": "1.9.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tone": "15.1.22"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.4",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
